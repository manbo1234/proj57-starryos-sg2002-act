+            );
+            return Err(IonError::NoMemory);
+        }
+
+        if CARVEOUT_NEXT
+            .compare_exchange(current, end, Ordering::AcqRel, Ordering::Acquire)
+            .is_err()
+        {
+            continue;
+        }
+
+        let paddr = PhysAddr::from_usize(start);
+        let vaddr = phys_to_virt(paddr);
+        let cpu_addr = NonNull::new(vaddr.as_mut_ptr()).ok_or(IonError::NoMemory)?;
+        let live = CARVEOUT_LIVE.fetch_add(1, Ordering::AcqRel) + 1;
+
+        info!(
+            "ION carveout alloc: size={}, alloc_size={}, paddr=0x{:x}, vaddr=0x{:x}, next=0x{:x}, live={}",
+            size,
+            alloc_size,
+            paddr.as_usize(),
+            vaddr.as_usize(),
+            end,
+            live
+        );
+
+        return Ok(DMAInfo {
+            cpu_addr,
+            bus_addr: ax_dma::phys_to_bus(paddr),
+        });
+    }
+}
+
+pub fn release_carveout_buffer() {
+    let old = CARVEOUT_LIVE.fetch_sub(1, Ordering::AcqRel);
+    if old == 0 {
+        CARVEOUT_LIVE.store(0, Ordering::Release);
+    } else if old == 1 {
+        CARVEOUT_NEXT.store(SG2002_ION_CARVEOUT_BASE, Ordering::Release);
+        info!("ION carveout reset: all carveout buffers released");
     }
