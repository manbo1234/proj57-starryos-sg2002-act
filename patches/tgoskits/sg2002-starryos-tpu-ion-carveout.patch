+fn alloc_carveout_buffer(size: usize, align: usize) -> IonResult<DMAInfo> {
+    let effective_align = align.max(PAGE_SIZE_4K);
+    let alloc_size = align_up_checked(size, PAGE_SIZE_4K)?;
+
+    loop {
+        let current = CARVEOUT_NEXT.load(Ordering::Acquire);
+        let start = align_up_checked(current, effective_align)?;
+        let end = start.checked_add(alloc_size).ok_or(IonError::NoMemory)?;
+
+        if end > SG2002_ION_CARVEOUT_END {
+            error!(
